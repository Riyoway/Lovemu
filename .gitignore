```gitignore
# Dependencies
node_modules/

# Frontend build output
dist/
dist-ssr/
*.local

# Vite
.vite/

# Tauri / Rust build output
src-tauri/target/
target/
debug/

# Rust backup files
**/*.rs.bk

# Rust / MSVC debug information
*.pdb

# Cargo mutation testing
**/mutants.out*/

# Environment variables
.env
.env.*
!.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor settings
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/

# OS-generated files
.DS_Store
Thumbs.db
desktop.ini
```
